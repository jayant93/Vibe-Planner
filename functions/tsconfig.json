{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "paths": {
      "shared/*": ["../packages/shared/src/*"],
      "shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
