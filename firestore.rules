rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents ────────────────────────────────────────────────────────
    match /users/{uid} {

      allow read: if request.auth != null && request.auth.uid == uid;

      // Block client from modifying server-only fields (subscription, aiUsage)
      allow update: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription', 'aiUsage']);

      // Allow creating own doc on first sign-in
      allow create: if request.auth != null && request.auth.uid == uid;

      // ── Tasks ───────────────────────────────────────────────────────────────
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── Habits ──────────────────────────────────────────────────────────────
      match /habits/{habitId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── AI Usage (read-only for client) ─────────────────────────────────────
      match /aiUsage/{date} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // ── Time Logs ────────────────────────────────────────────────────────────
      match /timeLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
